async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    if query.data == 'profile': await profile(update, context)
    elif query.data == 'search_info': await query.message.reply_text("📱 নম্বর পাঠান।")
    elif query.data == 'terms': await query.message.reply_text("⚖️ অবৈধ ব্যবহার নিষিদ্ধ।")
    elif query.data == 'support': await query.message.reply_text("📞 সাপোর্ট: @AdminUsername")

async def search_logic(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    if (datetime.now() - user_last_msg_time[user_id]).total_seconds() < flood_threshold: return
    user_last_msg_time[user_id] = datetime.now()
    
    text = update.message.text.strip()
    if not text.isdigit(): return

    allowed, remain = check_limit(user_id)
    if not allowed:
        await update.message.reply_text("🚫 লিমিট শেষ!")
        return

    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute("SELECT * FROM info WHERE number LIKE ?", ('%' + text,))
    results = cursor.fetchall()
    conn.close()

    if results:
        for r in results:
            await update.message.reply_text(f"✅ পাওয়া গেছে!\n👤 নাম: {r[1]}\n👴 পিতা: {r[4]}\n🆔 NID: {r[2]}\n🏠 শহর: {r[3]}\n📞 মোবাইল: {r[0]}")
    else:
        await update.message.reply_text(f"❌ ডাটা নেই। বাকি সার্চ: {remain}")

