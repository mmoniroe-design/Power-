# --- ডাটাবেজ ফাংশন ---
def init_db():
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute('''CREATE TABLE IF NOT EXISTS info (number TEXT PRIMARY KEY, name TEXT, nid TEXT, city TEXT, father TEXT)''')
    cursor.execute('''CREATE TABLE IF NOT EXISTS usage (user_id INTEGER PRIMARY KEY, count INTEGER, last_date TEXT, is_premium INTEGER DEFAULT 0)''')
    conn.commit()
    conn.close()

def check_limit(user_id):
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    today = datetime.now().strftime('%Y-%m-%d')
    cursor.execute("SELECT count, last_date, is_premium FROM usage WHERE user_id = ?", (user_id,))
    row = cursor.fetchone()
    
    if row:
        count, last_date, is_premium = row
        if is_premium == 1: return True, "Unlimited"
        if last_date != today:
            cursor.execute("UPDATE usage SET count = 1, last_date = ? WHERE user_id = ?", (today, user_id))
            conn.commit()
            return True, FREE_LIMIT - 1
        elif count < FREE_LIMIT:
            cursor.execute("UPDATE usage SET count = count + 1 WHERE user_id = ?", (user_id,))
            conn.commit()
            return True, FREE_LIMIT - (count + 1)
        return False, 0
    else:
        cursor.execute("INSERT INTO usage (user_id, count, last_date) VALUES (?, 1, ?)", (user_id, today))
        conn.commit()
        return True, FREE_LIMIT - 1

