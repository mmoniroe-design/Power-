        await context.bot.send_document(chat_id=ADMIN_ID, document=open(DB_FILE, 'rb'), caption="📅 Daily DB Backup.")
    except Exception as e: logging.error(f"Backup Error: {e}")

async def stats(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID: return
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()
    cursor.execute("SELECT COUNT(*) FROM usage")
    total_users = cursor.fetchone()[0]
    cursor.execute("SELECT COUNT(*) FROM usage WHERE is_premium = 1")
    premium_users = cursor.fetchone()[0]
    conn.close()
    await update.message.reply_text(f"📊 বট স্ট্যাটাস:\n\n👥 মোট ইউজার: {total_users}\n💎 প্রিমিয়াম ইউজার: {premium_users}")

